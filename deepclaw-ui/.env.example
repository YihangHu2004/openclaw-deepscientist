# DeepClaw UI — environment variables
# All settings are optional. Copy to .env and uncomment what you need.

# UI server port (default: 19000)
# DEEPCLAW_UI_PORT=19000

# OpenClaw home directory (default: ~/.openclaw on all platforms)
# OPENCLAW_HOME=/custom/path/to/.openclaw

# Workspace name or absolute path to the projects directory.
# Auto-detected by scanning ~/.openclaw/workspace-*/state/projects/.
# Set this if auto-detection picks the wrong workspace, or you have a custom path.
# Examples:
#   OPENCLAW_WORKSPACE=workspace-scientist        (name inside OPENCLAW_HOME)
#   OPENCLAW_WORKSPACE=/abs/path/to/projects      (absolute path)
# OPENCLAW_WORKSPACE=workspace-scientist

# Next.js dev proxy target (used during npm run dev in client/)
# Only relevant if you run the proxy server on a non-default port.
# SERVER_URL=http://127.0.0.1:19000
